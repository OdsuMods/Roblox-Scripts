if not getgenv().TeleportPos then
    warn("Teleport Script: No position set. Please set getgenv().TeleportPos first.")
    warn("Example: getgenv().TeleportPos = Vector3.new(100, 50, -200)")
    return
end
if typeof(getgenv().TeleportPos) ~= "Vector3" then
    error("Teleport Script: getgenv().TeleportPos must be a Vector3 value")
end
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local function teleport(position)
    -- Check if character exists and is valid
    if not character or not character.Parent then
        character = player.CharacterAdded:Wait()
        humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    end
    humanoidRootPart.CFrame = CFrame.new(position)
    print(string.format("Teleported to (%.1f, %.1f, %.1f)", position.X, position.Y, position.Z))
end
teleport(getgenv().TeleportPos)
getgenv().TeleportPos = nil
