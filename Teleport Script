-- Roblox Teleport Script by OdsuMods
-- Teleports LocalPlayer to a world position

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Get coordinates from global variables (set before loadstring)
local targetX = getgenv().TeleportX or 0
local targetY = getgenv().TeleportY or 5
local targetZ = getgenv().TeleportZ or 0

-- Wait for character
if not LocalPlayer.Character then
    LocalPlayer.CharacterAdded:Wait()
end

local character = LocalPlayer.Character
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Teleport
humanoidRootPart.CFrame = CFrame.new(targetX, targetY, targetZ)
